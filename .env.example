# CPS application runtime configuration for local development.
# Copy this file to .env. Never commit real credentials.

CPS_ENVIRONMENT=development
CPS_SERVICE_NAME=cps
CPS_LOG_LEVEL=INFO
CPS_DATABASE_URL=postgresql+psycopg://cps:cps_dev_password@127.0.0.1:5432/cps  # pragma: allowlist secret
CPS_RABBITMQ_URL=amqp://cmp:cmp_dev_password@127.0.0.1:5672/cmp  # pragma: allowlist secret
CPS_API_HOST=0.0.0.0
CPS_API_PORT=8000
