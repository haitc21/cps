{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "auth_url", "username", "password", "user_domain_name", "project_name", "project_domain_name", "region_name", "interface", "verify_tls"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\.[0-9]+$"},
    "auth_url": {"type": "string", "minLength": 1, "maxLength": 2048},
    "username": {"type": "string", "minLength": 1, "maxLength": 255},
    "password": {"type": "string", "minLength": 1, "maxLength": 4096},
    "user_domain_name": {"type": "string", "minLength": 1, "maxLength": 255},
    "project_name": {"type": "string", "minLength": 1, "maxLength": 255},
    "project_domain_name": {"type": "string", "minLength": 1, "maxLength": 255},
    "region_name": {"type": "string", "minLength": 1, "maxLength": 255},
    "interface": {"enum": ["public", "internal", "admin"]},
    "verify_tls": {"type": "boolean"},
    "ca_cert_pem": {"type": ["string", "null"], "maxLength": 32768}
  }
}
