# Copy this file to .env for local overrides. Never commit real credentials.

POSTGRES_DB=cps
POSTGRES_USER=cps
POSTGRES_PASSWORD=cps_dev_password
POSTGRES_PORT=5432

RABBITMQ_USER=cmp
RABBITMQ_PASSWORD=cmp_dev_password
RABBITMQ_VHOST=cmp
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Required for CPS credential encryption and local credential-resolution demos.
# Generate one with:
# python -c "import base64; print('v1:' + base64.b64encode(b'k' * 32).decode())"
CPS_CREDENTIAL_KEY_RING=v1:a2tra2tra2tra2tra2tra2tra2tra2tra2tra2tra2s=

CPS_PUBLIC_PORT=8000
CPS_INTERNAL_PORT=8002
OPS_API_PORT=8001
